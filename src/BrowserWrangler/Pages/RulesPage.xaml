<Page
    x:Class="BrowserWrangler.Pages.RulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Rules" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <TextBlock VerticalAlignment="Center" Text="Profile:" />
            <ComboBox x:Name="ProfileCombo" MinWidth="280" SelectionChanged="Profile_Changed" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Click="Add_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="Add rule" />
                </StackPanel>
            </Button>
            <Button x:Name="ClearAllButton" Click="ClearAll_Click" Content="Clear all" />
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RuleList" Spacing="8" />
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12">
            <TextBox x:Name="TestUrlBox" MinWidth="320" PlaceholderText="Test a URL against all rules..." />
            <Button Click="Test_Click" Content="Test" />
        </StackPanel>
    </Grid>
</Page>
